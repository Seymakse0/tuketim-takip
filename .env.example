# PostgreSQL — örnekler:
# Yerel Docker (docker-compose.yml, host portu 5434):
# DATABASE_URL="postgresql://tuketim:tuketim@127.0.0.1:5434/tuketim_kontrol?schema=public"
# Otel sunucusu veya başka kurulum:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tuketim_kontrol?schema=public"

# Bugünün tarihi bu saat dilimine göre belirlenir (mutfak girişi kilidi için)
APP_TIMEZONE="Europe/Istanbul"

# Otel ortak stil dosyası (tam URL). Boş bırakılırsa yalnızca uygulama stilleri kullanılır.
# Örnek: https://otel-domain.com/assets/hotel-common.css
NEXT_PUBLIC_HOTEL_CSS_URL=

# Giriş (zorunlu): en az 32 karakter rastgele dize. Üretmek için: openssl rand -hex 32
APP_AUTH_SECRET=buraya_uzun_rastgele_gizli_anahtar

# Kullanıcılar — biçim 1: pipe ile ayırın, kullanıcı:şifre (şifrede : kullanmayın)
# APP_AUTH_USERS="mutfak:gizli123|depo:baskaSifre"

# Kullanıcılar — biçim 2: JSON (şifrede özel karakter kullanabilirsiniz)
# APP_AUTH_USERS_JSON='[{"username":"mutfak","password":"gizli:123"}]'
APP_AUTH_USERS="admin:degistirin"
