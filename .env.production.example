# docker-compose.production.yml ile kullanın; dosyayı sunucuda .env olarak kopyalayın.
# Asla Git'e commit etmeyin.
#
# DATABASE_URL satırı gerekmez: compose app konteynerine postgresql://tuketim:${POSTGRES_PASSWORD}@db:5432/... verir.
# Yerelde npm run dev + host’taki Postgres için bilgisayarınızdaki .env’de DATABASE_URL kullanılır.

# Özel URL karakterleri (@ : # ?) kullanmayın veya şifreyi bu betikle DB ile eşitleyin: ./deploy/sync-postgres-password-from-env.sh
POSTGRES_PASSWORD=buraya_güçlü_bir_şifre_yazın

# Web girişi (zorunlu)
APP_AUTH_SECRET=openssl_rand_hex_32_ile_üretin
# Pipe: kullanici:sifre|diger:pass — şifrede # veya $ varsa JSON kullanın veya değeri çift tırnak içinde verin
APP_AUTH_USERS=mutfak:güçlü_şifre|depo:başka_şifre
# İsteğe bağlı tek satır JSON; dolu ve geçerliyse yalnızca bu kullanıcılar geçerli (pipe yok sayılır). Boş/geçersizse APP_AUTH_USERS kullanılır.
# APP_AUTH_USERS_JSON=[{"username":"mutfak","password":"şifre:nokta.izin"}]

# İsteğe bağlı: konteyner dışından başka bir Postgres kullanacaksanız app/db servislerini
# compose'tan çıkarıp yalnızca DATABASE_URL verirsiniz (ayrı dokümantasyon gerekir).
