# docker-compose.production.yml ile kullanın; dosyayı sunucuda .env olarak kopyalayın.
# Asla Git'e commit etmeyin.

POSTGRES_PASSWORD=buraya_güçlü_bir_şifre_yazın

# Web girişi (zorunlu)
APP_AUTH_SECRET=openssl_rand_hex_32_ile_üretin
APP_AUTH_USERS=mutfak:güçlü_şifre|depo:başka_şifre

# İsteğe bağlı: konteyner dışından başka bir Postgres kullanacaksanız app/db servislerini
# compose'tan çıkarıp yalnızca DATABASE_URL verirsiniz (ayrı dokümantasyon gerekir).
